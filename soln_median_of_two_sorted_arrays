void printArr(int *arr, int len, char *message){
    printf( "%s :", message );
    for( int index = 0; index < len; index++ ){
        printf("%d ", arr[index]);
    }
    printf("\n");
}


int* joinTwoArrays( int* nums1, int nums1Size, int* nums2, int nums2Size ){
    int joinedLength = nums1Size + nums2Size ;
    int *joined = calloc( joinedLength, sizeof(int) );
    int i = 0, j = 0, k = 0;
    while( i<nums1Size ){
        joined[k] = nums1[i] ;
        k = k + 1; i = i + 1; 
    }
   while( j<nums2Size ){
        joined[k] = nums2[j] ;
        k = k + 1; j = j + 1; 
    }
    
    return joined;
}

void mergeFromMidInPlace( int *arr, int len ){
    int *temp = calloc( len, sizeof(int) );
    int mid = len/2;
    int i = 0, j = mid, k = 0;
    while( i<mid && j<len ){
        if( arr[i]<arr[j] ){
            temp[k] = arr[i] ;
            k = k + 1; i = i + 1; 
        }
        else{
            temp[k] = arr[j] ;
            k = k + 1; j = j + 1;
        }
    }
    while( i<mid ){
        temp[k] = arr[i] ;
        k = k + 1; i = i + 1; 
    }
   while( j<len ){
        temp[k] = arr[j] ;
        k = k + 1; j = j + 1; 
    }
    
    for( int index = 0; index < len; index++ ){
        arr[index] = temp[index];
    }
    free( temp );
    
    return;

}

