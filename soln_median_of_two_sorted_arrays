    int midIndex = newLength / 2 ; 
    int value = merged[ midIndex ]; 

    if( newLength%2 == 0 ) { 
        value =  ( value + merged[ midIndex + 1 ] )/2 ;
    }
    
    //double result = medianOfSortedArray( merged, newLength );
    printf( "median : %d \n", value ) ;

    return value;
}

