
int isPalindrome( char *s ){
    int len = ( sizeof(s) )/( sizeof(*s) );
    int mid = len/2 ;
    int start = 0, end = len-1;

    while( start<=mid && end>=mid ){
        if( s[start] != s[end] ) return 0;
    }
    return true;
}

